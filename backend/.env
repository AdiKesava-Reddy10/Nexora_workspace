# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=nexora_workspace_secret_key_2026_secure
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# Database Connection (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=nexora_db

# Redis Caching (Optional fallback to memory cache if Redis is not running)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# AI API Configurations (Optional; blank triggers the smart local generator)
GEMINI_API_KEY=
OPENAI_API_KEY=

# Mail Settings (Optional mockup for OTP / Registration validation)
EMAIL_SERVICE=gmail
EMAIL_USER=noreply.nexora@gmail.com
EMAIL_PASS=pass
